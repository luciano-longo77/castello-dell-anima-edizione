            <!-- msItem II e III con stessa struttura -->
          </msContents>
          <physDesc>
            <objectDesc>
              <supportDesc>
                <support><p><material/><date/></p></support>
                <extent><dimensions><height/><width/></dimensions></extent>
                <condition><p/></condition>
              </supportDesc>
              <layoutDesc>
