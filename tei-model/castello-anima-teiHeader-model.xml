              </layoutDesc>
            </objectDesc>
            <handDesc>
              <handNote xml:id="ink_1"><p/></handNote>
              <handNote xml:id="ink_2"><p/></handNote>
              <handNote xml:id="ink_3-dark"><p/></handNote>
              <handNote xml:id="ink_4-external"><p/></handNote>
            </handDesc>
          </physDesc>
          <history>
            <origin>
              <p>
                <origPlace><placeName/></origPlace>
                <origDate/>
                <note/>
              </p>
            </origin>
          </history>
          <additional>
            <surrogates><p/></surrogates>
          </additional>
        </msDesc>
        <listBibl>
          <bibl/>
        </listBibl>
        <listWit>
          <witness/>
        </listWit>
